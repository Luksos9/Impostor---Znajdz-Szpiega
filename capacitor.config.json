{
  "appId": "com.lukaszsumilas.impostor",
  "appName": "Impostor",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#FFF8EC",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "launchFadeOutDuration": 300,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "overlaysWebView": false,
      "backgroundColor": "#FFF8EC",
      "style": "LIGHT"
    }
  }
}
